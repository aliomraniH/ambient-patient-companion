modules = ["python-3.12", "nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Config Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Clinical MCP Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Skills MCP Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Ingestion MCP Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd replit-app && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Config Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd replit_dashboard && python server.py"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Clinical MCP Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "MCP_TRANSPORT=streamable-http MCP_PORT=8001 python -m server.mcp_server"

[[workflows.workflow]]
name = "Skills MCP Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mcp-server && MCP_TRANSPORT=streamable-http MCP_PORT=8002 python server.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Ingestion MCP Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "MCP_TRANSPORT=streamable-http MCP_PORT=8003 python -m ingestion.server"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8001
externalPort = 3000

[[ports]]
localPort = 8002
externalPort = 3001

[[ports]]
localPort = 8003
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
SYNTHEA_OUTPUT_DIR = "/home/runner/synthea-output"
DATA_TRACK = "synthea"

[deployment]
deploymentTarget = "vm"
run = ["bash", "start.sh"]
build = ["bash", "-c", "pip install -r requirements.txt && pip install -r replit_dashboard/requirements.txt && cd replit-app && npm ci && npm run build"]
