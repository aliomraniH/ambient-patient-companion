  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "9. Pharmacologic Approaches to Glycemic Treatment",
    "section": "9.1",
    "recommendation_id": "9.1a",
    "text": "Metformin is the preferred initial pharmacologic agent for the treatment of type 2 diabetes.",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes"],
    "contraindications": ["eGFR < 30"],
    "medications_mentioned": ["metformin"],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "9. Pharmacologic Approaches to Glycemic Treatment",
    "section": "9.2",
    "recommendation_id": "9.2a",
    "text": "In patients with type 2 diabetes and established atherosclerotic cardiovascular disease (ASCVD), a GLP-1 receptor agonist with demonstrated cardiovascular benefit is recommended as part of the glucose-lowering regimen.",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes", "ascvd"],
    "contraindications": ["personal_or_family_history_medullary_thyroid_carcinoma", "MEN2_syndrome"],
    "medications_mentioned": ["liraglutide", "semaglutide", "dulaglutide"],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "9. Pharmacologic Approaches to Glycemic Treatment",
    "section": "9.2",
    "recommendation_id": "9.2b",
    "text": "In patients with type 2 diabetes and established ASCVD, an SGLT2 inhibitor with demonstrated cardiovascular benefit is recommended as part of the glucose-lowering regimen.",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes", "ascvd"],
    "contraindications": ["type_1_diabetes_dka_risk", "eGFR < 20"],
    "medications_mentioned": ["empagliflozin", "canagliflozin", "dapagliflozin"],
