  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "11. Chronic Kidney Disease and Risk Management",
    "section": "11.1",
    "recommendation_id": "11.1a",
    "text": "At least once a year, assess urinary albumin (e.g., spot urinary albumin-to-creatinine ratio [UACR]) and estimated glomerular filtration rate (eGFR) in patients with type 1 diabetes with duration of ≥5 years and in all patients with type 2 diabetes.",
    "evidence_grade": "B",
    "recommendation_strength": "Moderate",
    "patient_population": ["adults", "type_2_diabetes", "type_1_diabetes"],
    "contraindications": [],
    "medications_mentioned": [],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "11. Chronic Kidney Disease and Risk Management",
    "section": "11.2",
    "recommendation_id": "11.2a",
    "text": "For patients with type 2 diabetes and diabetic kidney disease, use of an SGLT2 inhibitor is recommended to reduce CKD progression and cardiovascular events in patients with an eGFR ≥20 mL/min/1.73 m².",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes", "ckd", "albuminuria"],
    "contraindications": ["eGFR < 20"],
    "medications_mentioned": ["empagliflozin", "canagliflozin", "dapagliflozin"],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
