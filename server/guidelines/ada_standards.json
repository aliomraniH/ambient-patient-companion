  },
  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "10. Cardiovascular Disease and Risk Management",
    "section": "10.2",
    "recommendation_id": "10.2a",
    "text": "Blood pressure should be measured at every routine clinical visit. Patients found to have elevated blood pressure (≥140/90 mmHg) should have blood pressure confirmed using multiple readings on a separate day to diagnose hypertension.",
