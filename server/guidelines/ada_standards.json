    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes"],
    "contraindications": [],
    "medications_mentioned": ["metformin", "SGLT2 inhibitors", "GLP-1 receptor agonists", "DPP-4 inhibitors", "thiazolidinediones", "sulfonylureas"],
