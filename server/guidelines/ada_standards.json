    "version": "2026",
    "chapter": "11. Chronic Kidney Disease and Risk Management",
    "section": "11.2",
    "recommendation_id": "11.2b",
    "text": "For patients with type 2 diabetes and CKD with albuminuria (UACR ≥30 mg/g), an ACE inhibitor or ARB is recommended to reduce the risk of kidney disease progression.",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes", "ckd", "albuminuria"],
    "contraindications": ["bilateral_renal_artery_stenosis", "pregnancy", "hyperkalemia"],
    "medications_mentioned": ["lisinopril", "ramipril", "losartan", "irbesartan"],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
