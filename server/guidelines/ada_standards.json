    "chapter": "6. Glycemic Targets",
    "section": "6.5",
    "recommendation_id": "6.5a",
    "text": "A1C testing should be performed at least two times a year in patients who are meeting treatment goals and who have stable glycemic control. A1C testing should be performed quarterly in patients whose therapy has changed or who are not meeting glycemic goals.",
    "evidence_grade": "B",
    "recommendation_strength": "Moderate",
    "patient_population": ["adults", "type_2_diabetes", "type_1_diabetes"],
    "contraindications": [],
