  },
  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "9. Pharmacologic Approaches to Glycemic Treatment",
    "section": "9.3",
    "recommendation_id": "9.3a",
    "text": "In patients with type 2 diabetes who have established heart failure (HFrEF or HFpEF), an SGLT2 inhibitor with proven benefit in this population is recommended to reduce risk of worsening heart failure and cardiovascular death.",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes", "heart_failure"],
    "contraindications": ["type_1_diabetes_dka_risk", "eGFR < 20"],
    "medications_mentioned": ["empagliflozin", "dapagliflozin"],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "9. Pharmacologic Approaches to Glycemic Treatment",
    "section": "9.4",
    "recommendation_id": "9.4a",
    "text": "In patients with type 2 diabetes and chronic kidney disease (CKD), an SGLT2 inhibitor is recommended to reduce risk of CKD progression and cardiovascular events.",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes", "ckd"],
    "contraindications": ["eGFR < 20"],
    "medications_mentioned": ["empagliflozin", "canagliflozin", "dapagliflozin"],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
    "guideline_source": "ADA",
    "version": "2026",
    "chapter": "9. Pharmacologic Approaches to Glycemic Treatment",
    "section": "9.5",
    "recommendation_id": "9.5a",
    "text": "In patients with type 2 diabetes where weight management is a priority, GLP-1 receptor agonists or dual GIP/GLP-1 receptor agonists with good efficacy for weight loss are preferred.",
    "evidence_grade": "A",
    "recommendation_strength": "Strong",
    "patient_population": ["adults", "type_2_diabetes", "obesity"],
    "contraindications": ["personal_or_family_history_medullary_thyroid_carcinoma", "MEN2_syndrome"],
    "medications_mentioned": ["semaglutide", "tirzepatide", "liraglutide"],
    "last_reviewed": "2026-01-15",
    "is_current": true
  },
  {
