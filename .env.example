# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── OpenAI (for Dual-LLM Deliberation Engine) ─────────────
OPENAI_API_KEY=sk-...

# ── LangSmith ──────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ambient-patient-companion

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ambient_patient

# ── MCP Server ─────────────────────────────────────────────
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Deliberation Engine ───────────────────────────────────
DELIBERATION_ENABLED=true
DELIBERATION_MAX_ROUNDS=3
DELIBERATION_CONVERGENCE_THRESHOLD=0.90
DELIBERATION_MAX_TOKENS_PER_RUN=30000

# Deliberation schedule (cron format)
DELIBERATION_SCHEDULE_PRE_ENCOUNTER=0 6 * * *
DELIBERATION_SCHEDULE_TEMPORAL=0 12 1 * *

# ── Compliance ─────────────────────────────────────────────
HIPAA_AUDIT_LOG=true
AI_DISCLOSURE_REQUIRED=true
