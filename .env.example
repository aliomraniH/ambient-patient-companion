# Required Environment Variables for Vercel Deployment

# PostgreSQL database connection string
# Example: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=

# Session secret for cookie encryption (generate a secure random string)
# Example: openssl rand -base64 32
SESSION_SECRET=

# Optional: Additional CORS allowed origins (comma-separated)
# Example: https://mydomain.com,https://api.mydomain.com
CORS_ALLOWED_ORIGINS=

# MCP Server URLs (external deployment required for Python servers)
# These are the URLs of your deployed MCP servers
# MCP_CLINICAL_URL=https://your-clinical-mcp-server.com
# MCP_SKILLS_URL=https://your-skills-mcp-server.com  
# MCP_INGESTION_URL=https://your-ingestion-mcp-server.com
